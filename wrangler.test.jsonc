{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "babyflow-test",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-16",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "babyflow-test",
      "database_id": "babyflow-test-local"
    }
  ]
}
